{
  "name": "jmg-ascensores",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "docs:generate": "compodoc -p tsconfig.app.json -d documentation",
    "test:unit": "vitest run",
    "e2e": "playwright test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/google-maps": "^21.1.4",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@fullcalendar/angular": "^6.1.20",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "rxjs": "~7.8.0",
    "signature_pad": "^5.1.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.6.0",
    "angular-eslint": "21.3.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.0.3",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0"
  }
}
